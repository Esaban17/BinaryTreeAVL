# Configuración de MongoDB Atlas
# Copia este archivo como .env y completa con tus credenciales reales

# URI de conexión a MongoDB Atlas
# Formato: mongodb+srv://usuario:contraseña@cluster.mongodb.net/
MONGODB_URI=mongodb+srv://tu-usuario:tu-contraseña@tu-cluster.mongodb.net/

# Nombre de la base de datos
DATABASE_NAME=avltree_db

# Nombre de la colección para almacenar los nodos del árbol
COLLECTION_NAME=nodes

# Configuraciones opcionales

# Timeout de conexión (en milisegundos)
# CONNECTION_TIMEOUT=10000

# Timeout de socket (en milisegundos)  
# SOCKET_TIMEOUT=10000

# Número máximo de reintentos de conexión
# MAX_CONNECTION_RETRIES=3

# Intervalo entre reintentos (en milisegundos)
# RETRY_INTERVAL=2000

# Habilitar logging de MongoDB (true/false)
# MONGODB_LOGGING=false

# Nivel de log (ERROR, WARN, INFO, DEBUG)
# LOG_LEVEL=INFO